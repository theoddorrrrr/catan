{
  "name": "catan",
  "private": true,
  "scripts": {
    "build": "pnpm -r build",
    "build:deploy": "pnpm -r build && cp -r packages/client/dist packages/server/public",
    "dev": "pnpm -r --parallel dev",
    "test": "pnpm -r test",
    "lint": "eslint packages/*/src/",
    "format": "prettier --write \"packages/*/src/**/*.{ts,tsx}\""
  },
  "devDependencies": {
    "typescript": "^5.5.0",
    "prettier": "^3.3.0"
  }
}
